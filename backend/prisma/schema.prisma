generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                   Int                  @id @default(autoincrement())
  email                String               @unique
  password             String
  name                 String
  role                 Role                 @default(USER)
  isDemo               Boolean              @default(false)
  refreshToken         String?
  resetToken           String?
  resetTokenExpiry     DateTime?
  createdAt            DateTime              @default(now())
  tasks                Task[]                @relation("TaskAssignee")
  createdTasks         Task[]                @relation("TaskCreator")
  createdProjects      Project[]             @relation("ProjectCreator")
  organizationMembers  OrganizationMember[]
  projectMembers       ProjectMember[]
}

model Organization {
  id          Int                  @id @default(autoincrement())
  name        String
  slug        String               @unique
  description String?
  isDemo      Boolean              @default(false)
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  members     OrganizationMember[]
  projects    Project[]

  @@index([isDemo])
}

model OrganizationMember {
  organizationId Int
  userId         Int
  role           OrganizationRole @default(MEMBER)
  createdAt      DateTime         @default(now())
  organization  Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user          User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([organizationId, userId])
  @@index([userId])
  @@index([organizationId, role])
}

model Project {
  id             Int           @id @default(autoincrement())
  organizationId Int
  name           String
  key            String
  description    String?
  status         ProjectStatus @default(PLANNING)
  startDate      DateTime?
  dueDate        DateTime?
  createdById    Int
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  createdBy      User          @relation("ProjectCreator", fields: [createdById], references: [id], onDelete: Restrict)
  members        ProjectMember[]
  tasks          Task[]

  @@unique([organizationId, key])
  @@index([organizationId, status])
  @@index([dueDate])
}

model ProjectMember {
  projectId Int
  userId    Int
  role      ProjectRole @default(CONTRIBUTOR)
  createdAt DateTime    @default(now())
  project   Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([projectId, userId])
  @@index([userId])
  @@index([projectId, role])
}

model Task {
  id          Int        @id @default(autoincrement())
  title       String
  description String?
  status      TaskStatus @default(PENDING)
  priority    Priority   @default(MEDIUM)
  dueDate     DateTime?
  userId      Int?
  projectId   Int?
  createdById Int?
  parentTaskId Int?
  demoKey     String?    @unique
  user        User?      @relation("TaskAssignee", fields: [userId], references: [id], onDelete: SetNull)
  createdBy   User?      @relation("TaskCreator", fields: [createdById], references: [id], onDelete: SetNull)
  project     Project?   @relation(fields: [projectId], references: [id], onDelete: Restrict)
  parentTask  Task?      @relation("TaskHierarchy", fields: [parentTaskId], references: [id], onDelete: SetNull)
  subtasks    Task[]     @relation("TaskHierarchy")
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([projectId, status])
  @@index([userId, status])
  @@index([projectId, priority])
  @@index([dueDate])
  @@index([parentTaskId])
}

enum Role {
  USER
  ADMIN
}

enum OrganizationRole {
  OWNER
  MANAGER
  MEMBER
}

enum ProjectRole {
  LEAD
  CONTRIBUTOR
  VIEWER
}

enum ProjectStatus {
  PLANNING
  ACTIVE
  ON_HOLD
  COMPLETED
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
}

